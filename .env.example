# Qline App Configuration

# --- Backend Settings ---
PORT=3001
BASE_URL=http://localhost:3001
FRONTEND_URL=http://localhost:5173

# --- Clover Integration ---
# Get these from the Clover Developer Dashboard
CLOVER_CLIENT_ID=your_clover_app_id
CLOVER_CLIENT_SECRET=your_clover_app_secret
CLOVER_API_URL=https://api.clover.com
CLOVER_ENVIRONMENT=sandbox

# --- Twilio Integration ---
# Get these from the Twilio Console
TWILIO_ACCOUNT_SID=your_twilio_account_sid
TWILIO_AUTH_TOKEN=your_twilio_auth_token
TWILIO_PHONE_NUMBER=your_twilio_phone_number

# --- Database ---
# The app uses a local SQLite database by default (qline.db)
